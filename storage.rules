rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ===== HELPERS =====
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===== POSTS (muro, feed, highlights, arena photos, etc.) =====
    // Path used in code: posts/{effectiveUserId}/filename.jpg (or .webm etc in future)
    // - Any logged-in user can READ (so friends see your posts, feed works, map highlights, etc.)
    // - Only the owner can WRITE (you can only upload to your own folder)
    match /posts/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // ===== USER ASSETS (avatars, covers, etc. if we use separate paths later) =====
    match /users/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // ===== CHAT VOICE NOTES (the important one for "notas de voz") =====
    // Paths used in code (sendVoiceNote):
    //   chat-voice/${chatId}/${timestamp}.webm
    //
    // For 1:1 private chats: chatId = the other user's UID (activeChat)
    // For group/squad sessions: chatId = the sessionId (showGroupChatModalFor)
    //
    // Why "any authenticated can write"?
    //   - In 1:1 the folder is named after the recipient, but the sender (you) is the one uploading.
    //   - In groups anyone in the session can send a voice note.
    //   - We gate "who can send to this chat" at the app level (you can only open a chat with someone you matched or in the group).
    //   - This is the standard pattern for chat/media in social apps.
    //
    // Reads are needed so the receiver can play the audio (new Audio(voiceUrl) or <audio>).
    //
    // Explicit create + read for maximum compatibility with Firebase SDK uploads.
    match /chat-voice/{chatId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    // ===== CHAT PHOTOS (1:1 and group session folders) =====
    match /chat-photos/{chatId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    // ===== PARTNER LOGOS (for gyms/stores/studios added by devs to the live map / GymPulse) =====
    // Path used in code (uploadPartnerLogoIfNeeded + partner marker rendering):
    //   partners/${pid}/logo-${timestamp}
    //
    // - Any authenticated user can READ (so the logos show on the public live map for everyone).
    // - Authenticated write (the client-side isDeveloper gate prevents non-devs from uploading; rules are permissive here for simplicity).
    // This fixes the bug where adding a partner with logo would upload fail (default deny), so logoUrl never set, and marker always showed fallback emoji instead of the logo img.
    match /partners/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ===== PROFILE PHOTOS =====
    match /profiles/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // ===== IDENTITY VERIFICATION (selfie + ID — owner only) =====
    match /verification/{userId}/{allPaths=**} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // ===== FUEL AI (meal photos for macro logging) =====
    // Path: fuel/{userId}/{timestamp}.jpg — owner-only write, authenticated read
    match /fuel/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // ===== MARKETPLACE PRODUCT IMAGES (admin uploads) =====
    match /marketplace/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // ===== DEFAULT DENY (everything else is locked) =====
    // This must stay last. More specific rules above take precedence.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
