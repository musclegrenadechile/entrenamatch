rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection - users can only read/write their own document
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Push tokens - only the owner can write their own token(s). Functions (admin) can read to send FCM to network.
    match /userPushTokens/{userId} {
      allow write: if isOwner(userId);
      allow read: if false; // server-side only via admin SDK
    }

    // Profiles - public read for discovery, only owner can write
    match /profiles/{userId} {
      allow read: if true; // Anyone can read profiles for matching
      allow write: if isOwner(userId);
    }

    // GymPulse live presence — one doc per live user (deleted when offline)
    match /livePresence/{userId} {
      allow read: if true;
      allow create, update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // Likes — mutual matching (A likes B → likes/{A}_{B})
    // IMPORTANT: read must allow get on non-existent docs (reciprocal check before match).
    // Rules that only check resource.data.* deny gets when the doc does not exist yet.
    match /likes/{likeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.liker == request.auth.uid
        && request.resource.data.liked is string
        && request.resource.data.liked != request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.liker == request.auth.uid
        && request.resource.data.liker == request.auth.uid;
      allow delete: if false;
    }

    // Sessions
    match /sessions/{sessionId} {
      allow read: if true; // Public sessions are discoverable (pre-alpha)
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        // Creator or existing participant (for admin actions, lastMessage updates, etc)
        resource.data.creatorId == request.auth.uid || 
        request.auth.uid in resource.data.participants ||
        // Self-join: allow a user to add themselves to participants even if not present yet in the old doc
        (request.resource.data.participants is list && request.auth.uid in request.resource.data.participants)
      );
      allow delete: if isAuthenticated() && 
        (resource.data.creatorId == request.auth.uid || 
         request.auth.uid in resource.data.participants);
    }

    // Squads
    match /squads/{squadId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.members is list
        && request.auth.uid in request.resource.data.members;
      allow update: if isAuthenticated() && (
        resource.data.createdBy == request.auth.uid ||
        (resource.data.members is list && request.auth.uid in resource.data.members) ||
        // Self-join: user adds themselves to members (mirrors sessions/participants)
        (request.resource.data.members is list && request.auth.uid in request.resource.data.members)
      );
      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isAuthenticated() && resource.data.senderId == request.auth.uid;
      }
    }

    // Passes — left swipes (deck exclusion across devices)
    // Deck source of truth is profiles/{uid}.swipePassedIds; this collection is secondary audit.
    match /passes/{passId} {
      allow read: if isAuthenticated()
        && resource.data.passer == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.passer == request.auth.uid
        && request.resource.data.passed is string
        && request.resource.data.passed != request.auth.uid;
      allow update, delete: if false;
    }

    // Matches — created only when both users liked each other (mutual)
    match /matches/{matchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.user1 is string
        && request.resource.data.user2 is string
        && (request.auth.uid == request.resource.data.user1 || request.auth.uid == request.resource.data.user2);
      allow update: if false;
      allow delete: if false;
    }

    // 1:1 Messages (between two matched users) — relaxed read for pre-alpha so live chat + previews + "Actualizar chats reales" work reliably between real accounts
    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && 
        (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
    }

    // Session messages (subcollection)
    // Read allowed for any authenticated (pre-alpha: sessions are discoverable, join to participate; relaxes timing on participants update for instant UX)
    // In production would be stricter: only participants or creator.
    match /sessions/{sessionId}/messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && resource.data.senderId == request.auth.uid;
    }

    // Beta feedback (private to the user who submitted, or readable by them)
    match /betaFeedback/{feedbackId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow update, delete: if false;
    }

    // Reports - anyone authenticated can create (for safety). Reporter can read their own reports.
    // For pre-alpha moderation, reporter reads; full admin panel can be added later.
    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && request.auth.uid == resource.data.reporterId;
      allow update, delete: if false;
    }

    // Profile Posts / Muro (wall) - makes profiles alive like FB wall
    // Public read so anyone can see posts when viewing a profile (pre-alpha discovery)
    // Create only by owner
    // Update: owner or anyone for likes/comments (pre-alpha relaxed for interactions; client controls what fields)
    // Delete only by owner
    match /profilePosts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        // Owner full control
        resource.data.userId == request.auth.uid ||
        // Anyone can participate in likes/comments (e.g. add to arrays)
        true
      );
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Real-time comments subcollection (primary persistence for muro threads)
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;
        allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated() && (
          resource.data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/profilePosts/$(postId)).data.userId == request.auth.uid
        );
      }
    }

    // Partner locations (gyms, studios, stores shown as gold "PARTNER" hubs + logos on the GymPulse live map)
    // - Public read: every user sees the partners on the map in realtime (no login required for viewing the map layer).
    // - Write (create/update/delete): any authenticated user.
    //   The UI is strictly gated client-side behind the developer password + isDeveloper mode
    //   (see openAddPartner, isDeveloper state, dev login modal). Non-devs can't even open the form.
    //   This mirrors the permissive-but-client-gated rule in storage.rules for /partners/** logos.
    //   Needed because the save (setDoc/updateDoc/deleteDoc to 'partnerLocations') was hitting the default deny.
    match /partnerLocations/{partnerId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }

    // EntrenaSync realtime sessions (shared actions, state between bonded pair for the Arena)
    // Pre-alpha relaxed: any auth can read/write the doc (the id is only known to the two participants via their profiles).
    // Client code controls who can start/join.
    match /syncSessions/{sessionId} {
      allow read, write: if isAuthenticated();
    }

    // Peer training reviews (cross-device, shown on profiles)
    match /trainingReviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.reviewerId == request.auth.uid
        && request.resource.data.profileId is string
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update, delete: if isAuthenticated() && resource.data.reviewerId == request.auth.uid;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
