rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection - users can only read/write their own document
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Profiles - public read for discovery, only owner can write
    match /profiles/{userId} {
      allow read: if true; // Anyone can read profiles for matching
      allow write: if isOwner(userId);
    }

    // Likes (for real matching logic, written by the liker)
    match /likes/{likeId} {
      allow create, update: if isAuthenticated() && request.auth.uid == request.resource.data.liker;
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.liker || request.auth.uid == resource.data.liked);
      allow delete: if false;
    }

    // Sessions
    match /sessions/{sessionId} {
      allow read: if true; // Public sessions are discoverable
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && 
        (resource.data.creatorId == request.auth.uid || 
         request.auth.uid in resource.data.participants);
    }

    // Squads
    match /squads/{squadId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    // Matches (for real multi-user matching)
    match /matches/{matchId} {
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.user1 || request.auth.uid == resource.data.user2);
      allow create: if isAuthenticated() && 
        (request.auth.uid == request.resource.data.user1 || request.auth.uid == request.resource.data.user2);
      allow update: if false; // matches are immutable once created
    }

    // 1:1 Messages (between two matched users)
    match /messages/{messageId} {
      allow read, write: if isAuthenticated() && 
        (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
      allow create: if isAuthenticated();
    }

    // Session messages (subcollection)
    // Read allowed for any authenticated (pre-alpha: sessions are discoverable, join to participate; relaxes timing on participants update for instant UX)
    // In production would be stricter: only participants or creator.
    match /sessions/{sessionId}/messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && resource.data.senderId == request.auth.uid;
    }

    // Beta feedback (private to the user who submitted, or readable by them)
    match /betaFeedback/{feedbackId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow update, delete: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
