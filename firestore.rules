rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    /** Lexicographic sorted pair — matches matchDocId() in matching.ts */
    function sortedMatchId(a, b) {
      return a <= b ? a + '_' + b : b + '_' + a;
    }

    function isMatchedWith(otherUid) {
      return isAuthenticated()
        && otherUid is string
        && otherUid != request.auth.uid
        && exists(/databases/$(database)/documents/matches/$(sortedMatchId(request.auth.uid, otherUid)));
    }

    function isMapEditor() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/mapEditors/$(request.auth.uid));
    }

    function isMarketplaceAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/marketplaceAdmins/$(request.auth.uid));
    }

    function isAppAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/appAdmins/$(request.auth.uid));
    }

    function validMarketplaceProduct(data) {
      return data.title is string
        && data.title.size() > 0
        && data.title.size() <= 120
        && data.description is string
        && data.description.size() <= 2000
        && data.priceClp is number
        && data.priceClp >= 0
        && data.priceClp <= 50000000
        && data.paymentUrl is string
        && data.paymentUrl.size() > 8
        && data.paymentUrl.matches('https://.*')
        && data.category is string
        && data.active is bool
        && data.createdBy == request.auth.uid
        && data.createdAt is number
        && data.updatedAt is number;
    }

    function validMarketplaceShipping(data) {
      return data.fullName is string
        && data.fullName.size() >= 3
        && data.fullName.size() <= 120
        && data.email is string
        && data.email.size() >= 5
        && data.email.size() <= 120
        && data.phone is string
        && data.phone.size() >= 8
        && data.phone.size() <= 20
        && data.address is string
        && data.address.size() <= 200
        && data.city is string
        && data.city.size() <= 80
        && data.region is string
        && data.region.size() <= 80;
    }

    function validMarketplaceOrder(data) {
      return data.userId == request.auth.uid
        && data.productId is string
        && data.productTitle is string
        && data.productTitle.size() <= 120
        && data.priceClp is number
        && data.priceClp >= 0
        && data.category is string
        && data.status == 'pending_payment'
        && validMarketplaceShipping(data.shipping)
        && data.createdAt is number;
    }

    function validTrainerProfile(data) {
      return data.displayName is string
        && data.displayName.size() >= 2
        && data.displayName.size() <= 80
        && data.bio is string
        && data.bio.size() <= 800
        && data.hourlyRateClp is number
        && data.hourlyRateClp >= 0
        && data.hourlyRateClp <= 500000
        && data.sessionDurationMin is number
        && data.sessionDurationMin >= 30
        && data.sessionDurationMin <= 180
        && data.active is bool
        && data.createdAt is number
        && data.updatedAt is number;
    }

    function validTrainerBookingCreate(data) {
      return data.clientId == request.auth.uid
        && data.trainerId is string
        && data.trainerId != request.auth.uid
        && data.trainerName is string
        && data.clientName is string
        && data.scheduledAt is number
        && data.durationMin is number
        && data.locationNote is string
        && data.locationNote.size() >= 3
        && data.priceClp is number
        && data.paymentMethod is string
        && data.status == 'requested'
        && data.createdAt is number
        && data.updatedAt is number;
    }

    function validTrainerDispatchCreate(data) {
      return data.clientId == request.auth.uid
        && data.clientName is string
        && data.specialty is string
        && data.durationMin is number
        && data.durationMin >= 30
        && data.durationMin <= 180
        && data.lat is number
        && data.lng is number
        && data.locationNote is string
        && data.locationNote.size() >= 3
        && data.paymentMethod is string
        && data.marketPriceClp is number
        && data.offerPriceClp is number
        && data.surgeFactor is number
        && data.platformFeeClp is number
        && data.status == 'searching'
        && data.candidateTrainerIds is list
        && data.candidateTrainerIds.size() > 0
        && data.passedTrainerIds is list
        && data.createdAt is number
        && data.updatedAt is number;
    }

    function dispatchCancelOnly() {
      return request.resource.data.clientId == resource.data.clientId
        && request.resource.data.offerPriceClp == resource.data.offerPriceClp
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);
    }

    function isTrainerBookingParty() {
      return isAuthenticated()
        && (resource.data.clientId == request.auth.uid
          || resource.data.trainerId == request.auth.uid);
    }

    function validTrainerBookingStatusUpdate() {
      return isTrainerBookingParty()
        && request.resource.data.trainerId == resource.data.trainerId
        && request.resource.data.clientId == resource.data.clientId
        && request.resource.data.priceClp == resource.data.priceClp
        && request.resource.data.scheduledAt == resource.data.scheduledAt
        && request.resource.data.createdAt == resource.data.createdAt
        && trainerBookingStatusTransition();
    }

    function trainerBookingStatusTransition() {
      let from = resource.data.status;
      let to = request.resource.data.status;
      let isTrainer = request.auth.uid == resource.data.trainerId;
      let isClient = request.auth.uid == resource.data.clientId;
      return (from == to && bookingMetaFieldsOnly())
        || (from == 'requested' && to == 'accepted' && isTrainer)
        || (from == 'requested' && to == 'declined' && isTrainer)
        || (from == 'requested' && to == 'cancelled' && isClient)
        || (from == 'accepted' && to == 'cancelled' && isClient)
        || (from == 'accepted' && to == 'in_progress' && isTrainer)
        || (from == 'in_progress' && to == 'completed' && isTrainerBookingParty())
        || (from == 'accepted' && to == 'completed' && isTrainerBookingParty())
        || (from == 'completed' && to == 'paid_cash' && isTrainerBookingParty())
        || (from == 'completed' && to == 'paid_card' && isClient);
    }

    function bookingMetaFieldsOnly() {
      return request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['reviewId', 'syncSessionId', 'updatedAt']);
    }

    function isSessionParticipant(sessionId) {
      let s = get(/databases/$(database)/documents/sessions/$(sessionId)).data;
      return isAuthenticated() && (
        request.auth.uid == s.creatorId
        || (s.participants is list && request.auth.uid in s.participants)
      );
    }

    function isSyncParticipantData(data) {
      return data.participants is list
        && data.participants.size() >= 1
        && data.participants.hasAny([request.auth.uid]);
    }

    function validSyncSessionCreate(data) {
      return data.participants is list
        && data.participants.size() == 2
        && request.auth.uid in data.participants
        && data.startedAt is number;
    }

    function syncWitnesses(data) {
      return data.witnesses is list ? data.witnesses : [];
    }

    /** Non-participants may append themselves to witnesses (GymPulse / feed viewers). */
    function isSyncWitnessUpdate() {
      return isAuthenticated()
        && !(request.auth.uid in resource.data.participants)
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.startedAt == resource.data.startedAt
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['witnesses', 'lastWitnessAt'])
        && request.resource.data.witnesses.hasAll(syncWitnesses(resource.data))
        && request.auth.uid in request.resource.data.witnesses;
    }

    /** Any authenticated user may toggle likes/reactions; only interaction fields may change. */
    function isPostInteractionUpdate() {
      return request.resource.data.userId == resource.data.userId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'likes',
          'reactions',
          'commentCount',
          'lastCommentAt',
          'updatedAt',
        ]);
    }

    // Users collection - users can only read/write their own document
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /derbyWeeklyWinners/{weekKey} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    match /userPushTokens/{userId} {
      allow write: if isOwner(userId);
      allow read: if false;
    }

    // Map partner editors — add UIDs manually in Firebase Console (P0 security)
    match /mapEditors/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /marketplaceAdmins/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /marketplaceProducts/{productId} {
      allow read: if isAuthenticated()
        && (resource.data.active == true || isMarketplaceAdmin());
      allow create: if isMarketplaceAdmin()
        && validMarketplaceProduct(request.resource.data);
      allow update: if isMarketplaceAdmin()
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isMarketplaceAdmin();
    }

    match /marketplaceOrders/{orderId} {
      allow create: if isAuthenticated()
        && validMarketplaceOrder(request.resource.data);
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isMarketplaceAdmin());
      allow update, delete: if isMarketplaceAdmin();
    }

    match /trainerProfiles/{userId} {
      allow read: if isAuthenticated()
        && (resource.data.active == true || isOwner(userId) || isMarketplaceAdmin());
      allow create: if isOwner(userId)
        && validTrainerProfile(request.resource.data)
        && (!('verified' in request.resource.data) || request.resource.data.verified == false);
      allow update: if isMarketplaceAdmin()
        || (isOwner(userId)
          && validTrainerProfile(request.resource.data)
          && request.resource.data.get('verified', false) == resource.data.get('verified', false));
      allow delete: if isOwner(userId) || isMarketplaceAdmin();
    }

    match /trainerBookings/{bookingId} {
      allow create: if isAuthenticated()
        && validTrainerBookingCreate(request.resource.data);
      allow read: if isAuthenticated()
        && (resource.data.clientId == request.auth.uid
          || resource.data.trainerId == request.auth.uid
          || isMarketplaceAdmin());
      allow update: if validTrainerBookingStatusUpdate();
      allow delete: if isMarketplaceAdmin();
    }

    match /trainerDispatchRequests/{dispatchId} {
      allow create: if isAuthenticated()
        && validTrainerDispatchCreate(request.resource.data);
      allow read: if isAuthenticated()
        && (resource.data.clientId == request.auth.uid
          || resource.data.currentTrainerId == request.auth.uid
          || resource.data.matchedTrainerId == request.auth.uid
          || request.auth.uid in resource.data.candidateTrainerIds
          || isMarketplaceAdmin());
      allow update: if isAuthenticated()
        && resource.data.clientId == request.auth.uid
        && resource.data.status in ['searching', 'offering']
        && request.resource.data.status == 'cancelled'
        && dispatchCancelOnly();
      allow delete: if isMarketplaceAdmin();
    }

    // Beta JS error breadcrumbs (non-fatal)
    match /clientErrorReports/{reportId} {
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 2000;
      allow read, update, delete: if false;
    }

    // Profiles — authenticated discovery (closed beta)
    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    /** Beta bots config — lectura para testers; escritura solo Admin SDK. */
    match /config/betaBots {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    /** AI identity verification attempts — written by Cloud Functions only. */
    match /identityVerifications/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
      match /attempts/{attemptId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }

    match /livePresence/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    match /likes/{likeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.liker == request.auth.uid
        && request.resource.data.liked is string
        && request.resource.data.liked != request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.liker == request.auth.uid
        && request.resource.data.liker == request.auth.uid;
      allow delete: if false;
    }

    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.creatorId == request.auth.uid ||
        request.auth.uid in resource.data.participants ||
        (request.resource.data.participants is list && request.auth.uid in request.resource.data.participants)
      );
      allow delete: if isAuthenticated() && (
        resource.data.creatorId == request.auth.uid ||
        request.auth.uid in resource.data.participants
      );
    }

    match /squads/{squadId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.members is list
        && request.auth.uid in request.resource.data.members;
      allow update: if isAuthenticated() && (
        resource.data.createdBy == request.auth.uid ||
        (resource.data.members is list && request.auth.uid in resource.data.members) ||
        (request.resource.data.members is list && request.auth.uid in request.resource.data.members)
      );
      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;

      match /messages/{messageId} {
        allow read: if isAuthenticated()
          && (request.auth.uid in get(/databases/$(database)/documents/squads/$(squadId)).data.members);
        allow create: if isAuthenticated()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/squads/$(squadId)).data.members;
        allow update, delete: if isAuthenticated() && resource.data.senderId == request.auth.uid;
      }
    }

    match /passes/{passId} {
      allow read: if isAuthenticated()
        && resource.data.passer == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.passer == request.auth.uid
        && request.resource.data.passed is string
        && request.resource.data.passed != request.auth.uid;
      allow update: if false;
      allow delete: if isAuthenticated()
        && resource.data.passer == request.auth.uid;
    }

    match /matches/{matchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.user1 is string
        && request.resource.data.user2 is string
        && (request.auth.uid == request.resource.data.user1 || request.auth.uid == request.resource.data.user2);
      allow update: if false;
      allow delete: if false;
    }

    // 1:1 Messages — only between matched users (P0 hardened)
    match /messages/{messageId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
      allow create: if isAuthenticated()
        && request.resource.data.from == request.auth.uid
        && request.resource.data.to is string
        && request.resource.data.to != request.auth.uid
        && isMatchedWith(request.resource.data.to);
      allow update, delete: if isAuthenticated()
        && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
    }

    match /sessions/{sessionId}/messages/{messageId} {
      allow read: if isSessionParticipant(sessionId);
      allow create: if isSessionParticipant(sessionId)
        && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.senderId == request.auth.uid;
    }

    match /betaFeedback/{feedbackId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow update, delete: if false;
    }

    match /appAdmins/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAppAdmin());
      allow write: if false;
    }

    match /adminAudit/{auditId} {
      allow read: if isAppAdmin();
      allow write: if false;
    }

    match /userBlocks/{blockId} {
      allow create: if isAuthenticated()
        && request.resource.data.blockerId == request.auth.uid
        && request.resource.data.blockedId is string
        && request.resource.data.blockedId != request.auth.uid
        && request.resource.data.timestamp is number;
      allow read: if isAuthenticated() && (
        resource.data.blockerId == request.auth.uid || isAppAdmin()
      );
      allow update, delete: if false;
    }

    function validReportCreate(data) {
      return data.reporterId == request.auth.uid
        && data.reportedUserId is string
        && data.reportedUserId != request.auth.uid
        && data.reason is string
        && data.reason.size() > 0
        && data.reason.size() <= 500
        && data.timestamp is number
        && data.status == 'pending';
    }

    match /reports/{reportId} {
      allow create: if isAuthenticated() && validReportCreate(request.resource.data);
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.reporterId || isAppAdmin()
      );
      allow update: if isAppAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reviewedAt']);
      allow delete: if false;
    }

    match /profilePosts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isPostInteractionUpdate()
      );
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;
        allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated() && (
          resource.data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/profilePosts/$(postId)).data.userId == request.auth.uid
        );
      }
    }

    match /partnerLocations/{partnerId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isMapEditor();
    }

    match /syncSessions/{sessionId} {
      allow read: if isAuthenticated()
        && isSyncParticipantData(resource.data);
      allow create: if isAuthenticated()
        && validSyncSessionCreate(request.resource.data);
      allow update: if isAuthenticated()
        && (isSyncParticipantData(resource.data) || isSyncWitnessUpdate());
      allow delete: if isAuthenticated()
        && isSyncParticipantData(resource.data);
    }

    match /trainingReviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.reviewerId == request.auth.uid
        && request.resource.data.profileId is string
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update, delete: if isAuthenticated() && resource.data.reviewerId == request.auth.uid;
    }

    match /workouts/{workoutId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    match /gymRoutines/{gymId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isMapEditor();
    }

    match /fuelProfiles/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    match /fuelLogs/{logId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    match /dailyEnergy/{docId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow write: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
    }

    match /constanciaBalances/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    match /partnerGymCheckIns/{checkInId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.gymId is string
        && request.resource.data.date is string;
      allow update, delete: if false;
    }

    match /partnerGymDaily/{dailyId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated()
        && request.resource.data.gymId is string
        && request.resource.data.date is string
        && request.resource.data.checkInCount is number
        && request.resource.data.checkInCount >= 1
        && request.resource.data.checkInCount <= 10000;
    }

    match /partnerGyms/{gymId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated()
        && request.resource.data.gymId is string
        && request.resource.data.name is string;
    }

    match /cityWeeklyStats/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.totalMinutes is number
        && request.resource.data.totalMinutes >= 0
        && request.resource.data.totalMinutes <= 500;
      allow update: if isAuthenticated()
        && request.resource.data.cityNorm == resource.data.cityNorm
        && request.resource.data.weekKey == resource.data.weekKey
        && request.resource.data.totalMinutes is number
        && request.resource.data.totalMinutes >= resource.data.totalMinutes
        && request.resource.data.totalMinutes <= resource.data.totalMinutes + 500;
    }

    match /cityWeeklyStats/{docId}/contributors/{uid} {
      allow read: if isAuthenticated();
      allow write: if isOwner(uid);
    }

    // Pilot — real EntrenaSync sessions (Fase 100 metric)
    match /pilotSyncSessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.sessionId == sessionId
        && request.resource.data.weekKey is string
        && request.resource.data.durationMin is number
        && request.resource.data.durationMin >= 2
        && request.resource.data.durationMin <= 480
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.recordedBy == request.auth.uid;
      allow update, delete: if false;
    }

    match /cityWaitlist/{docId} {
      allow read: if false;
      allow create: if isAuthenticated()
        && request.resource.data.email is string
        && request.resource.data.city is string;
      allow update, delete: if false;
    }

    match /pilotCohort/{cityNorm} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.memberCount == 1
        && request.resource.data.cityNorm is string;
      allow update: if isAuthenticated()
        && request.resource.data.cityNorm == resource.data.cityNorm
        && request.resource.data.memberCount is number
        && request.resource.data.memberCount >= resource.data.memberCount
        && request.resource.data.memberCount <= resource.data.memberCount + 1;
    }

    match /pilotCohort/{cityNorm}/members/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid)
        && request.resource.data.uid == uid;
      allow update: if isOwner(uid)
        && request.resource.data.uid == uid;
      allow delete: if false;
    }

    match /pilotWeeklyMetrics/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.realSyncCount == 1
        && request.resource.data.totalSyncMinutes is number
        && request.resource.data.totalSyncMinutes >= 2
        && request.resource.data.totalSyncMinutes <= 480;
      allow update: if isAuthenticated()
        && request.resource.data.weekKey == resource.data.weekKey
        && request.resource.data.cityNorm == resource.data.cityNorm
        && request.resource.data.realSyncCount is number
        && request.resource.data.realSyncCount >= resource.data.realSyncCount
        && request.resource.data.realSyncCount <= resource.data.realSyncCount + 1
        && request.resource.data.totalSyncMinutes is number
        && request.resource.data.totalSyncMinutes >= resource.data.totalSyncMinutes
        && request.resource.data.totalSyncMinutes <= resource.data.totalSyncMinutes + 480;
    }

    // Fase 121 — densidad piloto (invites, QR, stories, Sync Hour)
    match /pilotDensityWeekly/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.weekKey is string
        && request.resource.data.cityNorm is string
        && request.resource.data.invitesShared is number
        && request.resource.data.gymQrOpens is number
        && request.resource.data.syncStoriesShared is number
        && request.resource.data.syncHourClicks is number
        && request.resource.data.invitesShared <= 1
        && request.resource.data.gymQrOpens <= 1
        && request.resource.data.syncStoriesShared <= 1
        && request.resource.data.syncHourClicks <= 1;
      allow update: if isAuthenticated()
        && request.resource.data.weekKey == resource.data.weekKey
        && request.resource.data.cityNorm == resource.data.cityNorm
        && request.resource.data.invitesShared is number
        && request.resource.data.gymQrOpens is number
        && request.resource.data.syncStoriesShared is number
        && request.resource.data.syncHourClicks is number
        && request.resource.data.invitesShared >= resource.data.invitesShared
        && request.resource.data.invitesShared <= resource.data.invitesShared + 1
        && request.resource.data.gymQrOpens >= resource.data.gymQrOpens
        && request.resource.data.gymQrOpens <= resource.data.gymQrOpens + 1
        && request.resource.data.syncStoriesShared >= resource.data.syncStoriesShared
        && request.resource.data.syncStoriesShared <= resource.data.syncStoriesShared + 1
        && request.resource.data.syncHourClicks >= resource.data.syncHourClicks
        && request.resource.data.syncHourClicks <= resource.data.syncHourClicks + 1;
    }

    // Post-sync share funnel (offer / publish / skip / opt-out)
    match /syncShareWeekly/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.weekKey is string
        && request.resource.data.offers is number
        && request.resource.data.publishes is number
        && request.resource.data.skips is number
        && request.resource.data.optOutSets is number;
      allow update: if isAuthenticated()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.weekKey == resource.data.weekKey
        && request.resource.data.offers is number
        && request.resource.data.publishes is number
        && request.resource.data.skips is number
        && request.resource.data.optOutSets is number
        && request.resource.data.offers >= resource.data.offers
        && request.resource.data.offers <= resource.data.offers + 1
        && request.resource.data.publishes >= resource.data.publishes
        && request.resource.data.publishes <= resource.data.publishes + 1
        && request.resource.data.skips >= resource.data.skips
        && request.resource.data.skips <= resource.data.skips + 1
        && request.resource.data.optOutSets >= resource.data.optOutSets
        && request.resource.data.optOutSets <= resource.data.optOutSets + 1;
    }

    match /chatTyping/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    match /weeklyPlans/{docId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create, update: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && docId.matches('^' + request.auth.uid + '_.*');
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
