# Local dev only — copy to .env.local (never commit real values)
# Partner map editor UI password (min 8 chars). Also add your UID to Firestore mapEditors/{uid}.
VITE_DEV_MAP_PASSWORD=

# Fuel AI (Gemini) — server-side only. Set via Firebase Functions secret, NOT in client env:
#   firebase functions:secrets:set GEMINI_API_KEY
# Or run: .\scripts\setup-fuel-ai.ps1 -ApiKey "AIza..."

# Marketplace admin — add your Firebase UID in Firestore Console:
#   Collection: marketplaceAdmins
#   Document ID: {your-firebase-uid}
#   Fields (optional): { role: "developer", email: "you@example.com" }
# Orders with shipping data: marketplaceOrders/{orderId} (buyers create on checkout)
# EntrenaCoach Fase 2 — Mercado Pago (Cloud Functions config):
#   firebase functions:config:set mercadopago.access_token="APP_USR-..."
# Or env MERCADOPAGO_ACCESS_TOKEN on the function runtime.
# Webhook: mercadoPagoWebhook (auto-confirma paid_card en trainerBookings)
# Each product uses paymentUrl (https://...) — Mercado Pago link de pago or Stripe Payment Link.
