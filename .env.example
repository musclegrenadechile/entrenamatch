# Local dev only — copy to .env.local (never commit real values)

# GymSound — Spotify OAuth PKCE (solo client ID; NO uses client secret en el frontend)
# Dashboard: https://developer.spotify.com/dashboard
# Redirect URIs en la app de Spotify:
#   https://entrenamatch.web.app/
#   https://entrenamatch.web.app/spotify-callback.html   (APK — obligatorio)
#   http://localhost:5173/                             (dev local)
# Copia a .env.local y .env.production.local:
# VITE_SPOTIFY_CLIENT_ID=tu_client_id
# Partner map editor UI password (min 8 chars). Also add your UID to Firestore mapEditors/{uid}.
VITE_DEV_MAP_PASSWORD=

# Fuel AI (Gemini) — server-side only. Set via Firebase Functions secret, NOT in client env:
#   firebase functions:secrets:set GEMINI_API_KEY
# Or run: .\scripts\setup-fuel-ai.ps1 -ApiKey "AIza..."

# Marketplace admin — add your Firebase UID in Firestore Console:
#   Collection: marketplaceAdmins
#   Document ID: {your-firebase-uid}
#   Fields (optional): { role: "developer", email: "you@example.com" }
# Orders with shipping data: marketplaceOrders/{orderId} (buyers create on checkout)
# Optional: GymPulse map basemap (Fases 102 + 87)
# Prod builds (npm run build / deploy) set VITE_MAP_USE_MAPLIBRE=1 automatically.
# Local dev: uncomment to preview MapLibre vector tiles instead of Carto raster:
# VITE_MAP_USE_MAPLIBRE=1
# VITE_MAPLIBRE_STYLE_URL=https://demotiles.maplibre.org/style.json
# VITE_MAP_TILE_URL=https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png
#   .\scripts\setup-mp-production.ps1 -AccessToken "APP_USR-..." -WebhookSecret "tu-clave-webhook"
# Webhook MP (evento payment):
#   https://us-central1-entrenamatch.cloudfunctions.net/mercadoPagoWebhook
