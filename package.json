{
  "name": "entrenamatch",
  "private": true,
  "version": "0.1.508",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:landing-css": "tailwindcss -i ./src/landing/landing.css -o ./public/styles/landing-v2.css --minify",
    "build": "npm run build:landing-css && cross-env VITE_MAP_USE_MAPLIBRE=1 tsc --noEmit && cross-env VITE_MAP_USE_MAPLIBRE=1 vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "cross-env CAPACITOR= npm run build:landing-css && cross-env CAPACITOR= npm run build -- --base=/ && firebase deploy --only hosting --project entrenamatch",
    "deploy:pages": "echo GH Pages deprecated — use npm run deploy (Firebase entrenamatch.web.app)",
    "build:web": "cross-env VITE_MAP_USE_MAPLIBRE=1 tsc --noEmit && cross-env VITE_MAP_USE_MAPLIBRE=1 vite build",
    "build:web:native": "cross-env CAPACITOR=1 VITE_MAP_USE_MAPLIBRE=1 tsc --noEmit && cross-env CAPACITOR=1 VITE_MAP_USE_MAPLIBRE=1 vite build",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "ios:build": "npm run build:web:native && npx cap sync ios",
    "ios:open": "npm run ios:build && npx cap open ios",
    "android:build": "npm run build:web:native && npm run cap:sync",
    "android:apk": "npm run android:build && cd android && gradlew.bat assembleDebug",
    "android:device": "cross-env CAP_DEV=1 npm run build:web:native && cross-env CAP_DEV=1 npx cap sync android && cd android && gradlew.bat assembleDebug",
    "version:check": "node scripts/version-check.mjs",
    "pilot:cohort": "node scripts/pilot-cohort-report.mjs",
    "pilot:sync": "node scripts/pilot-sync-report.mjs",
    "pilot:reports": "node scripts/pilot-cohort-report.mjs && node scripts/pilot-sync-report.mjs",
    "build:release": "cd android && .\\gradlew.bat bundleRelease",
    "build:release:win": "build-release.bat",
    "publish:play": "publish-play.bat",
    "publish:play:internal": "publish-play.bat internal",
    "publish:play:closed": "publish-play.bat closed",
    "test:fuel": "npx tsx scripts/test-fuel-ai.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "qa:smoke": "node scripts/qa-smoke.mjs",
    "test:e2e": "playwright test",
    "setup:mp": "node scripts/setup-mp-production.mjs",
    "phase": "node scripts/implement-phase.mjs",
    "bots:pause": "node scripts/pause-beta-bots.mjs",
    "bots:resume": "node scripts/pause-beta-bots.mjs --resume",
    "recalculate:sync-streaks": "npx tsx scripts/recalculate-sync-streaks.ts",
    "recalculate:sync-streaks:apply": "npx tsx scripts/recalculate-sync-streaks.ts --apply"
  },
  "dependencies": {
    "@capacitor-community/play-integrity": "^8.0.0",
    "@capacitor-firebase/authentication": "^8.3.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/share": "^8.0.1",
    "@capgo/capacitor-health": "^8.6.3",
    "@maplibre/maplibre-gl-leaflet": "^0.1.3",
    "@tanstack/react-virtual": "^3.13.12",
    "canvas-confetti": "^1.9.4",
    "firebase": "^12.14.0",
    "framer-motion": "^12.40.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sonner": "^2.0.7",
    "supercluster": "^8.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.52.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^3.2.4"
  }
}
