{
  "name": "entrenamatch",
  "private": true,
  "version": "0.1.45-network-sync-boost",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "firebase deploy --only hosting",
    "build:web": "tsc -b && vite build",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "android:build": "cross-env CAPACITOR=1 npm run build:web && npm run cap:sync",
    "build:release": "cd android && .\\gradlew.bat bundleRelease",
    "build:release:win": "build-release.bat",
    "publish:play": "publish-play.bat",
    "publish:play:internal": "publish-play.bat internal",
    "publish:play:closed": "publish-play.bat closed"
  },
  "dependencies": {
    "@capacitor-community/play-integrity": "^8.0.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/push-notifications": "^8.1.1",
    "canvas-confetti": "^1.9.4",
    "firebase": "^12.14.0",
    "framer-motion": "^12.40.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
